---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="scene">
		<svg class="scene-svg" role="img" aria-label="Gothic bay window with porcelain doll" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 680 600">
		  <title>Gothic bay window forest storm</title>
		  <desc>Angled bay window with dark purple curtains, forest outside, storm, fog writing on center pane.</desc>
		  <defs>
		    <linearGradient id="scene-bg" x1="0" y1="0" x2="0" y2="800" gradientUnits="userSpaceOnUse">
		      <stop offset="0" stop-color="#16121a" />
		      <stop offset="1" stop-color="#0b0a0f" />
		    </linearGradient>
		    <linearGradient id="storm-sky" x1="0" y1="80" x2="0" y2="600" gradientUnits="userSpaceOnUse">
		      <stop offset="0" stop-color="#1d1c28" />
		      <stop offset="0.6" stop-color="#12111b" />
		      <stop offset="1" stop-color="#0b0b12" />
		    </linearGradient>
		    <linearGradient id="glass-sheen" x1="140" y1="80" x2="1060" y2="600" gradientUnits="userSpaceOnUse">
		      <stop offset="0" stop-color="#8f93a5" stop-opacity="0.25" />
		      <stop offset="0.4" stop-color="#cfd2de" stop-opacity="0.08" />
		      <stop offset="1" stop-color="#6a6f86" stop-opacity="0.2" />
		    </linearGradient>
		    <linearGradient id="wood-frame" x1="100" y1="40" x2="1100" y2="640" gradientUnits="userSpaceOnUse">
		      <stop offset="0" stop-color="#6a4328" />
		      <stop offset="0.45" stop-color="#3f2715" />
		      <stop offset="1" stop-color="#744c2e" />
		    </linearGradient>
		    <linearGradient id="wood-trim" x1="0" y1="0" x2="0" y2="1">
		      <stop offset="0" stop-color="#7a5232" />
		      <stop offset="1" stop-color="#3a2314" />
		    </linearGradient>
		    <radialGradient id="vignette" cx="50%" cy="45%" r="70%">
		      <stop offset="0" stop-color="#000" stop-opacity="0" />
		      <stop offset="1" stop-color="#000" stop-opacity="0.55" />
		    </radialGradient>
		    <pattern id="rain" width="26" height="90" patternUnits="userSpaceOnUse" patternTransform="translate(0 0) skewX(-12)">
		      <line x1="5" y1="-20" x2="5" y2="90" stroke="#d7dcf5" stroke-width="1.6" stroke-linecap="round" opacity="0.55" />
		      <line x1="18" y1="0" x2="18" y2="96" stroke="#d7dcf5" stroke-width="1.2" stroke-linecap="round" opacity="0.35" />
		    </pattern>
		    <filter id="fog-blur" x="-10%" y="-10%" width="120%" height="120%">
		      <feGaussianBlur stdDeviation="6" />
		    </filter>
		    <filter id="rain-blur" x="-10%" y="-10%" width="120%" height="120%">
		      <feGaussianBlur stdDeviation="0.4" />
		    </filter>
		    <filter id="fog-text-blur" x="-10%" y="-10%" width="120%" height="120%">
		      <feGaussianBlur stdDeviation="2.6" />
		    </filter>
		    <clipPath id="window-clip">
		      <rect x="140" y="80" width="920" height="520" rx="22" />
		    </clipPath>
		    <style>
		      .scene-bg {
		        fill: url(#scene-bg);
		      }

		      .scene-vignette {
		        fill: url(#vignette);
		      }

		      .window-frame {
		        fill: url(#wood-frame);
		        stroke: #2b1b10;
		        stroke-width: 10;
		      }

		      .window-inner {
		        fill: #0f0c0a;
		      }

		      .storm-sky {
		        fill: url(#storm-sky);
		      }

		      .cloud {
		        fill: #14121a;
		        opacity: 0.7;
		      }

		      .rain {
		        fill: url(#rain);
		        opacity: 0.5;
		        filter: url(#rain-blur);
		      }

		      .glass {
		        fill: url(#glass-sheen);
		        opacity: 0.35;
		      }

		      .glass-streak {
		        fill: none;
		        stroke: #b9bed3;
		        stroke-width: 2;
		        opacity: 0.25;
		      }

		      .mullion {
		        fill: #1a1520;
		        opacity: 0.85;
		      }

		      .fog {
		        fill: #d8d6e2;
		        opacity: 0.24;
		        filter: url(#fog-blur);
		      }

		      .fog-text {
		        fill: none;
		        stroke: #ece8f4;
		        stroke-width: 4.2;
		        opacity: 0.95;
		        filter: url(#fog-text-blur);
		        stroke-linecap: round;
		        stroke-linejoin: round;
		      }

		      .lightning-flash {
		        fill: #e9ecff;
		        opacity: 0;
		      }

		      .ledge-base {
		        fill: #2f1d12;
		      }

		      .ledge-top {
		        fill: url(#wood-trim);
		      }

		      .ledge-front {
		        fill: #24160d;
		      }

		      .bay-top {
		        fill: url(#wood-trim);
		      }

		      .bay-front {
		        fill: #23150c;
		      }

		      .bay-side {
		        fill: #3a2416;
		      }

		      .curtain {
		        fill: #4a2a6b;
		      }

		      .curtain-fold {
		        fill: #5b3380;
		        opacity: 0.8;
		      }

		      .curtain-shadow {
		        fill: #2f1a44;
		        opacity: 0.7;
		      }

		      .curtain-ring {
		        fill: #6b3b9a;
		      }

		      .curtain-tab {
		        fill: #3e235c;
		      }

		      .curtain-rod {
		        fill: #3a2616;
		      }

		      .curtain-rod-highlight {
		        fill: #5a3b22;
		        opacity: 0.7;
		      }

		      .curtain-rod-cap {
		        fill: #27180f;
		      }

		      .curtain-header {
		        fill: #432766;
		      }
		    </style>
